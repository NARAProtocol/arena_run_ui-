{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/arena",
  "framework": "vite",
  "redirects": [
    {
      "source": "/",
      "destination": "/arena",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/arena/(.*)",
      "destination": "/arena/index.html"
    }
  ]
}
